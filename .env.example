# Database (Local Setup)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/raone

# Database (Docker Setup - Use service name 'db')
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/raone

# Postgres credentials (for Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=raone

# JWT
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# LLM Providers
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# App Config
APP_NAME=RAONE
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:8000
